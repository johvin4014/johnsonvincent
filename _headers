  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Strict-Transport-Security: max-age=31536000
  Content-Security-Policy: default-src 'self'; img-src 'self' https: data:; script-src 'self' https://skillicons.dev; style-src 'self' 'unsafe-inline'; font-src https:; connect-src 'self';
